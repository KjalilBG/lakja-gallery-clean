generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum AlbumStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum AlbumVisibility {
  PUBLIC_LINK
  PASSWORD
}

enum CoverPosition {
  TOP
  CENTER
  BOTTOM
}

enum PhotoStatus {
  PROCESSING
  READY
  FAILED
}

enum DownloadType {
  SINGLE
  FAVORITES_ZIP
  FULL_ZIP
}

enum FavoriteSelectionStatus {
  PENDING
  EDITING
  DELIVERED
}

enum JobType {
  GENERATE_PREVIEW
  GENERATE_ZIP
  OCR_BIB
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CoberturaStatus {
  AGENDADO
  SOLICITADO
  REALIZADO
  CANCELADO
}

enum PaymentType {
  HOURLY
  FLAT
  MIXED
}

enum HistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  STAFF_REASSIGNED
  DUPLICATED
  DELETED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  role          UserRole  @default(ADMIN)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  albums        Album[]
  shortLinks    ShortLink[]
  createdCoberturas   Cobertura[]         @relation("CoberturaCreatedBy")
  updatedCoberturas   Cobertura[]         @relation("CoberturaUpdatedBy")
  staffAssignments    CoberturaStaff[]
  coberturaHistory    CoberturaHistory[]
  coverageNotes       CoverageStaffNote[]
  hourlyRates         StaffHonorario[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Album {
  id                     String           @id @default(cuid())
  slug                   String           @unique
  title                  String
  clientName             String
  description            String?
  eventDate              DateTime?
  status                 AlbumStatus      @default(DRAFT)
  visibility             AlbumVisibility  @default(PUBLIC_LINK)
  coverPosition          CoverPosition    @default(CENTER)
  coverFocusX            Int              @default(50)
  coverFocusY            Int              @default(50)
  passwordHash           String?
  fullDownloadPasswordHash String?
  allowSingleDownload    Boolean          @default(true)
  allowFavoritesDownload Boolean          @default(true)
  allowFullDownload      Boolean          @default(false)
  bibRecognitionEnabled  Boolean          @default(false)
  bibRecognitionProcessedAt DateTime?
  isFeatured             Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  createdById            String?
  coverPhotoId           String?          @unique
  createdBy              User?            @relation(fields: [createdById], references: [id])
  photos                 Photo[]          @relation("AlbumPhotos")
  coverPhoto             Photo?           @relation("AlbumCover", fields: [coverPhotoId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  favorites              Favorite[]
  downloads              Download[]
  views                  AlbumView[]
  jobs                   Job[]
  favoriteSelections     FavoriteSelection[]
}

model Photo {
  id          String      @id @default(cuid())
  albumId     String
  filename    String
  originalKey String
  previewKey  String?
  thumbKey    String?
  capturedAt  DateTime?
  width       Int?
  height      Int?
  sizeBytes   Int?
  detectedBibs String[]   @default([])
  bibOcrText   String?
  bibOcrProcessedAt DateTime?
  sortOrder   Int         @default(0)
  status      PhotoStatus @default(PROCESSING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  album       Album       @relation("AlbumPhotos", fields: [albumId], references: [id], onDelete: Cascade)
  albumCover  Album?      @relation("AlbumCover")
  favorites   Favorite[]
  downloads   Download[]
  selectionItems FavoriteSelectionItem[]

  @@index([albumId, sortOrder])
}

model FavoriteSelection {
  id           String                  @id @default(cuid())
  albumId      String
  sessionId    String
  clientName   String
  message      String?
  whatsapp     String?
  status       FavoriteSelectionStatus @default(PENDING)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  album        Album                   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  items        FavoriteSelectionItem[]

  @@index([albumId, createdAt])
}

model FavoriteSelectionItem {
  id                   String             @id @default(cuid())
  favoriteSelectionId  String
  photoId              String
  sortOrder            Int
  createdAt            DateTime           @default(now())
  favoriteSelection    FavoriteSelection  @relation(fields: [favoriteSelectionId], references: [id], onDelete: Cascade)
  photo                Photo              @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([favoriteSelectionId, sortOrder])
  @@unique([favoriteSelectionId, photoId])
}

model Favorite {
  id         String   @id @default(cuid())
  albumId    String
  photoId    String
  sessionId  String
  createdAt  DateTime @default(now())
  album      Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, sessionId])
  @@index([albumId, sessionId])
}

model Download {
  id         String       @id @default(cuid())
  albumId    String
  photoId    String?
  sessionId  String
  type       DownloadType
  createdAt  DateTime     @default(now())
  album      Album        @relation(fields: [albumId], references: [id], onDelete: Cascade)
  photo      Photo?       @relation(fields: [photoId], references: [id], onDelete: SetNull)

  @@index([albumId, createdAt])
}

model AlbumView {
  id         String   @id @default(cuid())
  albumId    String
  sessionId  String
  createdAt  DateTime @default(now())
  album      Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId, createdAt])
}

model Job {
  id         String    @id @default(cuid())
  albumId    String?
  type       JobType
  status     JobStatus @default(PENDING)
  payload    Json
  attempts   Int       @default(0)
  runAt      DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  album      Album?    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([status, runAt])
}

model SiteSettings {
  id                  String   @id @default("default")
  shareTitle          String   @default("La Kja | Galerias fotograficas premium")
  shareDescription    String   @default("Galerias fotograficas premium para clientes y administracion de albumes.")
  shareImageUrl       String?
  instagramUrl        String?
  facebookUrl         String?
  whatsappNumber      String?
  whatsappMessage     String?
  maintenanceMode     Boolean  @default(false)
  maintenanceTitle    String   @default("Estamos afinando la experiencia de La Kja")
  maintenanceMessage  String   @default("Estamos trabajando en mejoras para que la experiencia se sienta mas cuidada. Mientras tanto, puedes escribirme directamente por WhatsApp o volver en un momento.")
  showWhatsAppFloat   Boolean  @default(true)
  downloadsEnabled    Boolean  @default(true)
  favoritesEnabled    Boolean  @default(true)
  downloadPopupEnabled Boolean @default(true)
  featuredAlbumIds    String[] @default([])
  downloadPopupTitle  String   @default("Tu descarga ya comenzo 📸✨")
  downloadPopupBody   String   @default("Gracias por estar aqui. Comparte este momento, etiquetanos y forma parte de nuestra comunidad.")
  homeBadge           String   @default("Estamos construyendo algo especial")
  homeEyebrow         String   @default("Bienvenido a La Kja")
  homeTitle           String   @default("Una experiencia fotografica mas cercana, mas viva y mas tuya.")
  homeDescription     String   @default("Estamos afinando una nueva casa digital para entregar historias, retratos y eventos con una experiencia mucho mas cuidada. Mientras tanto, ya puedes recorrer las galerias publicadas, sentir el estilo de La Kja y escribirme si quieres crear algo juntos.")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AdminNotebook {
  ownerEmail String   @id
  content    String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShortLink {
  id            String   @id @default(cuid())
  slug          String   @unique
  destinationUrl String
  title         String?
  note          String?
  isActive      Boolean  @default(true)
  clicks        Int      @default(0)
  lastClickedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  clickEvents   ShortLinkClick[]

  @@index([isActive, updatedAt])
}

model ShortLinkClick {
  id           String    @id @default(cuid())
  shortLinkId  String
  referer      String?
  sourceHost   String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  country      String?
  city         String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  shortLink    ShortLink  @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, createdAt])
  @@index([createdAt])
  @@index([sourceHost])
  @@index([utmSource])
}

model Campus {
  id          String      @id @default(cuid())
  nombre      String      @unique
  slug        String      @unique
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  coberturas  Cobertura[]
  lugares     Lugar[]
}

model Seccion {
  id          String      @id @default(cuid())
  nombre      String      @unique
  slug        String      @unique
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  coberturas  Cobertura[]
  presets     CoveragePreset[]
}

model Lugar {
  id          String      @id @default(cuid())
  nombre      String
  slug        String
  campusId    String?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  campus      Campus?     @relation(fields: [campusId], references: [id], onDelete: SetNull)
  coberturas  Cobertura[]
  presets     CoveragePreset[]

  @@unique([campusId, slug])
  @@index([campusId, nombre])
}

model Cobertura {
  id                String               @id @default(cuid())
  folio             Int
  nombre            String
  fecha             DateTime
  horaInicio        String
  duracion          Int
  carpetaNombre     String
  campusId          String?
  seccionId         String?
  lugarId           String?
  estatus           CoberturaStatus      @default(AGENDADO)
  comentarios       String?
  detalles          String?
  createdById       String
  updatedById       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  campus            Campus?              @relation(fields: [campusId], references: [id], onDelete: SetNull)
  seccion           Seccion?             @relation(fields: [seccionId], references: [id], onDelete: SetNull)
  lugar             Lugar?               @relation(fields: [lugarId], references: [id], onDelete: SetNull)
  createdBy         User                 @relation("CoberturaCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User?                @relation("CoberturaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  staffAssignments  CoberturaStaff[]
  history           CoberturaHistory[]
  staffNotes        CoverageStaffNote[]

  @@unique([fecha, folio])
  @@index([fecha, estatus])
  @@index([campusId, seccionId, lugarId])
}

model CoberturaStaff {
  id            String      @id @default(cuid())
  coberturaId   String
  userId        String
  isLead        Boolean     @default(false)
  confirmedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cobertura     Cobertura   @relation(fields: [coberturaId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coberturaId, userId])
  @@index([userId, createdAt])
}

model CoverageStaffNote {
  id            String      @id @default(cuid())
  coberturaId   String
  userId        String
  nota          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cobertura     Cobertura   @relation(fields: [coberturaId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([coberturaId, createdAt])
}

model StaffHonorario {
  id             String        @id @default(cuid())
  userId         String
  paymentType    PaymentType   @default(HOURLY)
  costoHora      Decimal?      @db.Decimal(10, 2)
  transporte     Decimal?      @db.Decimal(10, 2)
  reglaIguala1a2 Decimal?      @db.Decimal(10, 2)
  reglaIguala3a4 Decimal?      @db.Decimal(10, 2)
  reglaIguala5Plus Decimal?    @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules          StaffHonorarioRule[]

  @@unique([userId])
}

model StaffHonorarioRule {
  id            String         @id @default(cuid())
  honorarioId   String
  label         String?
  desdeHoras    Decimal?       @db.Decimal(10, 2)
  hastaHoras    Decimal?       @db.Decimal(10, 2)
  montoFijo     Decimal?       @db.Decimal(10, 2)
  costoHora     Decimal?       @db.Decimal(10, 2)
  transporte    Decimal?       @db.Decimal(10, 2)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  honorario     StaffHonorario @relation(fields: [honorarioId], references: [id], onDelete: Cascade)

  @@index([honorarioId, sortOrder])
}

model CoberturaHistory {
  id            String         @id @default(cuid())
  coberturaId   String
  userId        String?
  action        HistoryAction
  field         String?
  beforeValue   String?
  afterValue    String?
  createdAt     DateTime       @default(now())
  cobertura     Cobertura      @relation(fields: [coberturaId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([coberturaId, createdAt])
}

model CoveragePreset {
  id          String    @id @default(cuid())
  nombre      String    @unique
  slug        String    @unique
  duracion    Int
  lugarId     String?
  seccionId   String?
  comentarios String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lugar       Lugar?    @relation(fields: [lugarId], references: [id], onDelete: SetNull)
  seccion     Seccion?  @relation(fields: [seccionId], references: [id], onDelete: SetNull)
}
